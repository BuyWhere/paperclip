# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/db?schema=public"

# --- Meta (Pixel + Conversions API) ---
# NEXT_PUBLIC_META_PIXEL_ID is exposed to the browser and is required for
# the Meta Pixel to load. Set to the numeric Pixel ID from Facebook Business
# Manager > Data Sources > Pixels.
# See src/components/MetaPixel.tsx and src/app/api/meta/capi/route.ts.
NEXT_PUBLIC_META_PIXEL_ID=

# META_PIXEL_ID and META_CAPI_ACCESS_TOKEN are server-only — DO NOT prefix
# with NEXT_PUBLIC_. Get the CAPI access token from:
# Facebook Business Manager > Data Sources > Pixels > Settings >
# Conversions API > Generate access token.
# See src/app/api/meta/capi/route.ts.
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=

# --- PostHog ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Other ---
ORCHESTRATOR_URL=https://orchestrator-production-1643.up.railway.app
ADMIN_SECRET=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
