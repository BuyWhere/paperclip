{
  "name": "8os-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --passWithNoTests --coverage --coverageThreshold='{\"global\":{\"lines\":80}}'",
    "test:integration": "jest --passWithNoTests --testPathPattern='__tests__/auth'",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/nextjs": "^10.51.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/uuid": "^10.0.0",
    "bcryptjs": "^3.0.3",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "next": "^14.2.35",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "posthog-js": "^1.372.10",
    "posthog-node": "^5.33.4",
    "prisma": "^7.8.0",
    "qrcode": "^1.5.4",
    "rate-limiter-flexible": "^11.1.0",
    "react": "^18",
    "react-dom": "^18",
    "speakeasy": "^2.0.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/react": "18.3.29",
    "@types/react-dom": "^18",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "5.9.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^jose$": "<rootDir>/src/__mocks__/jose.js",
      "^uuid$": "<rootDir>/src/__mocks__/uuid.js"
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  }
}
