ORCHESTRATOR_ENVIRONMENT=development
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8000
ORCHESTRATOR_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/8os
ORCHESTRATOR_REDIS_URL=redis://localhost:6379/0
# REQUIRED in production — generate with: openssl rand -hex 32
ORCHESTRATOR_JWT_SECRET=change-me-in-production
ORCHESTRATOR_JWT_EXPIRATION_MINUTES=60
# Required for admin access to GET /api/waitlist on the dashboard
# Generate with: openssl rand -hex 32
ADMIN_SECRET=change-me-in-production

# Observability (optional — leave blank to disable)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLOW_RESPONSE_THRESHOLD_MS=500
