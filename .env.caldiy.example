# Cal.diy Integration (OS-78)
# Self-hosted scheduling platform based on Cal.com

# URL of your Cal.diy instance
# For production: https://your-caldiy-domain.com
# For local development: http://localhost:3000
NEXT_PUBLIC_CALDIY_URL=https://your-caldiy-instance.com

# API Key from Cal.diy admin settings (for server-side API calls)
# Generate this in Cal.diy Settings > API Keys
CALDIY_API_KEY=your-caldiy-api-key-here
